{
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "jsxFactory": "Widget.jsx",
    "jsxFragmentFactory": "Widget.Fragment",
    "jsxImportSource": "ags/gtk4",
    "lib": [
      "ESNext",
      "DOM"
    ],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "paths": {
      "resource://*": [
        "./types/*"
      ]
    },
    "target": "ES2020"
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "types/**/*.d.ts"
  ]
}